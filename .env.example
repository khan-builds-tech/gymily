# Copy to .env and fill in. Never commit real secrets.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only (Fastify). NEVER bundle in the mobile app.

# --- Mobile (Expo public env, EXPO_PUBLIC_ prefix is exposed to the app) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_API_URL=http://localhost:8787

# --- Google ---
GOOGLE_PLACES_API_KEY=        # server-only
GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_ID=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- API ---
PORT=8787   # 8080 is commonly taken (e.g. by Apache) on macOS
